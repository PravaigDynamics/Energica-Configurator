# Energica Configurator — Backend Environment Template
# Copy to .env and fill in real values.

# Path to the extracted layer directories (absolute or relative to this file)
LAYER_PATH=./layers

# Redis connection URL (optional — service falls back to in-memory cache)
REDIS_URL=redis://localhost:6379/0

# HTTP port the compositor service listens on
PORT=8000

# CORS origins allowed to call the API (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Image quality for JPEG output (1-95)
JPEG_QUALITY=85

# Cache TTL in seconds (default: 30 days)
CACHE_TTL=2592000
