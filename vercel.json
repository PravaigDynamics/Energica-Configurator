{
    "framework": "nextjs",
    "buildCommand": "cd frontend && npm install --include=dev && npm run build",
    "outputDirectory": "frontend/.next",
    "functions": {
        "api/backend.py": {
            "maxDuration": 60,
            "includeFiles": "backend/**"
        }
    },
    "rewrites": [
        { "source": "/api/backend/:path*", "destination": "/api/backend" }
    ]
}
